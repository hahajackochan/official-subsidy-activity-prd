# 仅用于说明变量名，不要把真实值提交到 GitHub。
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=[REDACTED]
ALLOWED_TENANT_KEYS=["tenant_key_from_feishu_user_info"]
SESSION_SECRET=[REDACTED_RANDOM_32_BYTES_OR_LONGER]
SESSION_TTL_SECONDS=28800
# 创建 Pages 项目并获得正式域名后再填写；不填时自动使用当前站点 origin。
OAUTH_REDIRECT_URI=https://your-project.pages.dev/auth/callback
